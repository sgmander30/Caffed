{%- comment -%}
  Simple cart page matching the theme style.
{%- endcomment -%}

<section class="section">
  <div class="container">
    <div class="section-title">
      <h2>Cart</h2>
      <div class="bar"></div>
    </div>

    {%- if cart.item_count == 0 -%}
      <div class="card" style="padding:24px; text-align:center;">
        <p style="color: rgba(232,212,139,0.9); margin:0 0 16px;">Your cart is empty.</p>
        <a class="btn" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <div class="card" style="padding: 0; overflow:hidden;">
          <div style="padding: 16px 18px; border-bottom: 1px solid rgba(200,168,78,0.2); display:flex; justify-content:space-between; gap:16px; align-items:center;">
            <strong style="letter-spacing: .14em; text-transform: uppercase; font-size: 12px;">Items</strong>
            <span class="pill">{{ cart.item_count }}</span>
          </div>

          <div style="padding: 10px 18px;">
            {%- for item in cart.items -%}
              <div style="display:grid; grid-template-columns: 84px 1fr auto; gap:14px; align-items:center; padding:14px 0; border-top: 1px solid rgba(200,168,78,0.12);">
                <a href="{{ item.url }}" style="display:block;">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 168 }}" alt="{{ item.image.alt | escape }}" width="84" height="84" style="width:84px;height:84px;object-fit:cover;border:1px solid rgba(200,168,78,0.18); background: rgba(26,26,26,0.6);" loading="lazy">
                  {%- else -%}
                    <div style="width:84px;height:84px;border:1px solid rgba(200,168,78,0.18); background: rgba(26,26,26,0.6);"></div>
                  {%- endif -%}
                </a>

                <div>
                  <a href="{{ item.url }}" class="product-title" style="display:inline-block; margin:0 0 4px;">{{ item.product.title }}</a>
                  {%- if item.variant.title != 'Default Title' -%}
                    <div class="muted" style="font-size:12px;">{{ item.variant.title }}</div>
                  {%- endif -%}
                  <div style="display:flex; gap:10px; align-items:center; margin-top:10px;">
                    <label class="muted" for="updates_{{ item.key }}" style="font-size:12px;">Qty</label>
                    <input id="updates_{{ item.key }}" name="updates[{{ item.key }}]" type="number" min="0" value="{{ item.quantity }}" style="width:80px; background: transparent; border: 1px solid rgba(200,168,78,0.35); padding: 10px 10px; color:#fff;">
                    <a class="muted" href="{{ item.url_to_remove }}" style="font-size:12px;">Remove</a>
                  </div>
                </div>

                <div style="text-align:right;">
                  <div class="price">{{ item.final_line_price | money }}</div>
                  {%- if item.original_line_price > item.final_line_price -%}
                    <div class="muted" style="text-decoration: line-through; font-size:12px;">{{ item.original_line_price | money }}</div>
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div style="display:grid; grid-template-columns: 1fr; gap: 16px; margin-top: 18px;">
          <div class="card" style="padding:18px;">
            <div style="display:flex; justify-content:space-between; align-items:center; gap: 16px;">
              <div class="muted" style="letter-spacing:.18em; text-transform:uppercase; font-size: 12px;">Subtotal</div>
              <div class="price" style="font-size: 18px;">{{ cart.total_price | money }}</div>
            </div>
            {%- if cart.taxes_included or shop.shipping_policy.body != blank -%}
              <p class="muted" style="font-size: 12px; margin-top: 10px;">
                {%- if cart.taxes_included -%}Taxes included. {%- endif -%}
                {%- if shop.shipping_policy.body != blank -%}Shipping calculated at checkout.{%- endif -%}
              </p>
            {%- endif -%}
            <div style="display:flex; gap: 10px; margin-top: 14px; flex-wrap: wrap;">
              <button class="btn btn--ghost" type="submit" name="update">Update</button>
              <button class="btn" type="submit" name="checkout">Checkout</button>
            </div>
          </div>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}

