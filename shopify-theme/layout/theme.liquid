<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>
      {%- if template == 'index' -%}
        {{ shop.name }}
      {%- else -%}
        {{ page_title }}{% if current_tags %} – {{ current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} – Page {{ current_page }}{% endif %} – {{ shop.name }}
      {%- endif -%}
    </title>

    {{ content_for_header }}

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'theme.js' | asset_url | script_tag }}
  </head>

  <body class="caffed-body">
    <a class="caffed-skip-link" href="#MainContent">Skip to content</a>

    {% section 'announcement-bar' %}
    {% section 'header' %}

    <main id="MainContent" role="main">
      {{ content_for_layout }}
    </main>

    {% section 'footer' %}
  </body>
</html>
